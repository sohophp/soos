{
  "name": "soos",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/api.js\" \"vite --host 127.0.0.1\"",
    "dev:api": "node server/api.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "test:structured-data": "node tests/structured-data.test.js",
    "test:googlebot-log": "node tests/googlebot-log.test.js",
    "test:gsc-sitemaps": "node tests/gsc-sitemaps.test.js",
    "test:url-inspection-candidates": "node tests/url-inspection-candidates.test.js",
    "test:internal-crawl": "node tests/internal-crawl.test.js",
    "check": "node --check server/api.js && node --check api/index.js && npm run test:structured-data && npm run test:googlebot-log && npm run test:gsc-sitemaps && npm run test:url-inspection-candidates && npm run test:internal-crawl && npm run build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "undici": "^7.16.0",
    "vite": "^6.3.5"
  }
}
